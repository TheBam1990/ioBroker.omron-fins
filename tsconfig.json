{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": false,
    "module": "commonjs",
    "moduleResolution": "node"
  },
  "include": ["main.js", "lib/**/*.js", "lib/**/*.d.ts", "test/**/*.js", "main.test.js"],
  "exclude": ["node_modules", "lib/tools.js", "admin"]
}
